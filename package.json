{
  "name": "polymath-ide",
  "version": "1.0.0",
  "description": "Polymath IDE Full Stack — Multi-Agent AI Code Editor with Monaco Editor, Express/TypeScript backend & 3 AI agents",
  "author": "Isaac Ramirez <isaac.rma9@gmail.com>",
  "license": "MIT",
  "keywords": [
    "ide",
    "monaco-editor",
    "multi-agent",
    "ai",
    "typescript",
    "expressjs",
    "nodejs",
    "code-editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/101isack101/polymath-ide.git"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node dist/server.js",
    "dev": "ts-node server.ts",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
